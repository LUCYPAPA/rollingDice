page {
  background: #1A0A06;
  height: 100%;
}

.page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #1A0A06;
}

.msg-list {
  flex: 1;
  padding: 16px 12px;
  box-sizing: border-box;
}

.msg-row {
  display: flex;
  margin-bottom: 14px;
}

.msg-row.user {
  justify-content: flex-end;
}

.msg-row.assistant {
  justify-content: flex-start;
}

.bubble {
  max-width: 72%;
  padding: 10px 14px;
  border-radius: 16px;
  font-size: 15px;
  line-height: 1.6;
  word-break: break-all;
}

.msg-row.user .bubble {
  background: #C0392B;
  color: #FFFFFF;
  border-bottom-right-radius: 4px;
}

.msg-row.assistant .bubble {
  background: rgba(212,172,13,0.15);
  color: #F5E6B0;
  border: 0.5px solid rgba(212,172,13,0.3);
  border-bottom-left-radius: 4px;
}

.loading {
  color: rgba(245,230,176,0.5) !important;
}

.input-bar {
  display: flex;
  align-items: center;
  padding: 10px 12px;
  padding-bottom: calc(10px + env(safe-area-inset-bottom));
  background: rgba(255,255,255,0.05);
  border-top: 0.5px solid rgba(212,172,13,0.2);
  gap: 8px;
}

.input {
  flex: 1;
  background: rgba(255,255,255,0.08);
  border: 0.5px solid rgba(212,172,13,0.3);
  border-radius: 20px;
  padding: 10px 16px;
  color: #FFFFFF;
  font-size: 15px;
}

.placeholder {
  color: rgba(255,255,255,0.3);
}

.send-btn {
  width: 60px;
  height: 38px;
  border-radius: 19px;
  background: rgba(212,172,13,0.3);
  color: rgba(212,172,13,0.5);
  font-size: 14px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.send-btn.active {
  background: #D4AC0D;
  color: #2C1810;
  font-weight: bold;
}
