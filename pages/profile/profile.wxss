page {
  background-color: #1A0A06;
}

.page {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 48rpx 60rpx;
  min-height: 100vh;
  box-sizing: border-box;
}

.title {
  color: #D4AC0D;
  font-size: 34rpx;
  font-weight: bold;
  margin-bottom: 12rpx;
}

.hint {
  color: rgba(255,255,255,0.35);
  font-size: 24rpx;
  margin-bottom: 40rpx;
}

/* 头像按钮 */
.avatar-wrap {
  position: relative;
  width: 160rpx;
  height: 160rpx;
  padding: 0 !important;
  margin: 0 0 40rpx !important;
  background: none !important;
  border: none !important;
  line-height: 0 !important;
}
.avatar-wrap::after { display: none; }

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  border: 3rpx solid rgba(212,172,13,0.5);
}

.avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  border: 3rpx dashed rgba(212,172,13,0.35);
  background: rgba(212,172,13,0.05);
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-icon {
  font-size: 64rpx;
  line-height: 1;
}

.avatar-badge {
  position: absolute;
  right: 0;
  bottom: 0;
  width: 44rpx;
  height: 44rpx;
  border-radius: 22rpx;
  background: #C0392B;
  color: #fff;
  font-size: 20rpx;
  text-align: center;
  line-height: 44rpx;
}

/* 输入框 */
.input-wrap {
  width: 100%;
  border: 1rpx solid rgba(255,255,255,0.15);
  border-radius: 12rpx;
  padding: 0 28rpx;
  box-sizing: border-box;
  margin-bottom: 24rpx;
  background: rgba(255,255,255,0.05);
}

.input {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  color: #fff;
  font-size: 30rpx;
}

.placeholder {
  color: rgba(255,255,255,0.22);
}

/* 确认按钮 */
.btn-confirm {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #C0392B !important;
  color: #fff !important;
  font-size: 30rpx !important;
  font-weight: bold !important;
  border-radius: 12rpx !important;
  margin: 0 0 20rpx !important;
  padding: 0 !important;
}
.btn-confirm::after { display: none; }

/* 跳过 */
.btn-skip {
  background: none !important;
  border: none !important;
  color: rgba(255,255,255,0.28) !important;
  font-size: 24rpx !important;
  padding: 0 !important;
  margin: 0 !important;
  height: auto !important;
  line-height: 1.5 !important;
}
.btn-skip::after { display: none; }
